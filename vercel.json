{
  "version": 2,
  "functions": {
    "api/report.js": {
      "runtime": "edge"
    },
    "api/test.js": {
      "runtime": "edge"
    }
  },
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": { 
        "pythonVersion": "3.11",
        "includeFiles": ["index.html", "test.html", "simple_test.html", "*.jpg", "*.png", "*.jpeg"] 
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/test.html",
      "dest": "test.html"
    },
    {
      "src": "/simple_test.html",
      "dest": "simple_test.html"
    },
    {
      "src": "/",
      "dest": "app.py"
    },
    {
      "src": "/generate_report",
      "dest": "app.py"
    },
    {
      "src": "/stream_report",
      "dest": "app.py"
    },
    {
      "src": "/(.*\\.(jpg|jpeg|png|gif|webp))",
      "dest": "app.py"
    }
  ]
}
