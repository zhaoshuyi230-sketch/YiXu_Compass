{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": { 
        "pythonVersion": "3.11",
        "includeFiles": ["index.html", "*.jpg", "*.png", "*.jpeg"] 
      }
    }
  ],
  "routes": [
    {
      "src": "/api/report",
      "dest": "/api/report.js"
    },
    {
      "src": "/",
      "dest": "app.py"
    },
    {
      "src": "/generate_report",
      "dest": "app.py"
    },
    {
      "src": "/stream_report",
      "dest": "app.py"
    },
    {
      "src": "/(.*\\.(jpg|jpeg|png|gif|webp))",
      "dest": "app.py"
    }
  ]
}
